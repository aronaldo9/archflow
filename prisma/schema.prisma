generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id          String      @id @default(cuid())
  name        String
  code        String
  description String?
  status      String      @default("planning")
  phase       String      @default("concept")
  location    String?
  budget      Float       @default(0)
  spent       Float       @default(0)
  progress    Int         @default(0)
  startDate   DateTime
  endDate     DateTime
  clientName  String
  clientEmail String?
  clientPhone String?
  type        String      @default("administrative")
  tags        String?
  latitude    Float?
  longitude   Float?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  milestones  Milestone[]
  documents   Document[]
  expenses    Expense[]
  activityLog ActivityLog[]
  team        TeamMember[]
}

model Milestone {
  id        String   @id @default(cuid())
  title     String
  completed Boolean  @default(false)
  dueDate   DateTime
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Document {
  id         String   @id @default(cuid())
  name       String
  fileUrl    String
  uploadedAt DateTime @default(now())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Expense {
  id          String   @id @default(cuid())
  description String
  amount      Float
  category    String   @default("other")
  date        DateTime
  createdAt   DateTime @default(now())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id          String   @id @default(cuid())
  type        String
  description String
  createdAt   DateTime @default(now())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model TeamMember {
  id        String   @id @default(cuid())
  name      String
  role      String
  email     String?
  phone     String?
  createdAt DateTime @default(now())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}
